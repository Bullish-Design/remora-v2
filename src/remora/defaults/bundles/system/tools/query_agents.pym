# Query the node graph for agents. Filter by node_type or role.
from grail import external


@external
async def graph_query_nodes(
    node_type: str | None,
    status: str | None,
    file_path: str | None = None,
    role: str | None = None,
) -> list[dict]: ...


# Input defaults are not currently honored by grail runtime, so this tool keeps
# a no-argument interface and queries all agents.
agents = await graph_query_nodes(None, None, None, None)
result = str(agents)
result

# Send a message to another agent or to 'user' for chat responses.
from grail import Input, external

to_node_id: str = Input("to_node_id")
content: str = Input("content")


@external
async def send_message(to_node_id: str, content: str) -> bool: ...


result = await send_message(to_node_id, content)
if result:
    message = f"Message sent to {to_node_id}"
else:
    message = f"Failed to send message to {to_node_id}"
message

# Rewrite this code element's source code with new_source. Use carefully - changes are applied immediately.
from grail import Input, external

new_source: str = Input("new_source")


@external
async def apply_rewrite(new_source: str) -> bool: ...


success = await apply_rewrite(new_source)
if success:
    message = "Rewrite applied successfully."
else:
    message = "Rewrite failed: the source could not be applied."
message
